<%# REFERENCE: the verified-joining screen — one URL, four states, all
    decided by Organizations::JoinState so the page and its actions can never
    disagree. Copy + retheme (see JoinsController's header for the
    production checklist: rate limiting, consent copy). %>

<div class="mx-auto max-w-lg">
  <div class="mb-8 text-center">
    <span class="mx-auto mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-600 text-2xl font-bold text-white">
      <%= @organization.name.first.upcase %>
    </span>
    <h1 class="text-2xl font-bold text-gray-900"><%= @organization.name %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= @organization.member_count %> members</p>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <% case @state.status %>
    <% when :member %>

      <div class="text-center">
        <%= heroicon "check-circle", variant: :outline, options: { class: "mx-auto h-12 w-12 text-green-500" } %>
        <h2 class="mt-2 text-lg font-semibold text-gray-900">You're a member!</h2>
        <p class="mt-1 text-sm text-gray-500">You already belong to <%= @organization.name %>.</p>
        <%= link_to "Go to dashboard", root_path,
              class: "mt-4 inline-flex items-center rounded-lg bg-slate-600 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
      </div>

    <% when :verifying %>

      <h2 class="text-lg font-semibold text-gray-900">Check your inbox</h2>
      <p class="mt-1 text-sm text-gray-500">
        We sent a 6-digit code to <span class="font-medium text-gray-900"><%= @state.challenge.verification_email %></span>.
      </p>

      <%= form_with url: join_path(@organization), method: :post, class: "mt-4 space-y-3" do |form| %>
        <%= form.text_field :verification_code,
              autofocus: true, autocomplete: "one-time-code", inputmode: "numeric", maxlength: 6,
              placeholder: "123456",
              class: "block w-full rounded-lg border-gray-300 text-center text-2xl tracking-[0.5em] focus:border-slate-500 focus:ring-slate-500" %>
        <%= form.submit "Verify", class: "w-full rounded-lg bg-slate-600 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700 cursor-pointer" %>
      <% end %>

      <%# resend_seconds derives from gem config — never mirror the throttle
          as a magic number in your app. %>
      <div class="mt-4 border-t border-gray-100 pt-4 text-center text-sm text-gray-500">
        <% if @state.resend_seconds.zero? %>
          <%= form_with url: join_path(@organization), method: :post, class: "inline" do |form| %>
            <%= form.hidden_field :email, value: @state.challenge.verification_email %>
            <%= form.submit "Resend code", class: "font-medium text-slate-600 hover:text-slate-800 cursor-pointer bg-transparent border-0 p-0" %>
          <% end %>
        <% else %>
          You can request another code in <%= @state.resend_seconds %>s.
        <% end %>
      </div>

    <% when :pending %>

      <div class="text-center">
        <%= heroicon "clock", variant: :outline, options: { class: "mx-auto h-12 w-12 text-amber-500" } %>
        <h2 class="mt-2 text-lg font-semibold text-gray-900">Request pending</h2>
        <p class="mt-1 text-sm text-gray-500">An admin of <%= @organization.name %> will review your request.</p>
        <%= button_to "Withdraw request", withdraw_join_path(@organization), method: :delete,
              class: "mt-4 text-sm font-medium text-gray-500 hover:text-red-600 cursor-pointer bg-transparent" %>
      </div>

    <% when :entry %>

      <h2 class="text-lg font-semibold text-gray-900">Join <%= @organization.name %></h2>

      <%# The capability predicates decide which forms exist — an org with no
          domains never shows an email form, etc. %>
      <% if @organization.accepts_domain_joining? %>
        <%= form_with url: join_path(@organization), method: :post, class: "mt-4 space-y-3" do |form| %>
          <label class="block text-sm font-medium text-gray-700">Your work email</label>
          <%= form.email_field :email, placeholder: "you@company.com", required: true,
                class: "block w-full rounded-lg border-gray-300 focus:border-slate-500 focus:ring-slate-500" %>
          <%= form.submit "Send verification code", class: "w-full rounded-lg bg-slate-600 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700 cursor-pointer" %>
        <% end %>
      <% end %>

      <% if @organization.accepts_code_joining? %>
        <div class="<%= "mt-4 border-t border-gray-100 pt-4" if @organization.accepts_domain_joining? %>">
          <%= form_with url: join_path(@organization), method: :post, class: "space-y-3" do |form| %>
            <label class="block text-sm font-medium text-gray-700">Have a join code?</label>
            <%= form.text_field :code, placeholder: "XXXX-XXXX",
                  class: "block w-full rounded-lg border-gray-300 uppercase tracking-widest focus:border-slate-500 focus:ring-slate-500" %>
            <%= form.submit "Join with code", class: "w-full rounded-lg border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 cursor-pointer" %>
          <% end %>
        </div>
      <% end %>

      <% unless @organization.accepts_join_requests? %>
        <p class="mt-2 text-sm text-gray-500">This organization is not accepting join requests right now.</p>
      <% end %>

    <% end %>
  </div>
</div>
